    <script>
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      gsap.registerPlugin(ScrollTrigger);

      const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;

      // Section fade-in (in-view class — for existing CSS transitions)
      const philosophyEls = document.querySelectorAll(".philosophy");
      const fadeObs = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("in-view");
            }
          });
        },
        { threshold: 0.12 }
      );
      philosophyEls.forEach((s) => fadeObs.observe(s));

      if (!prefersReducedMotion) {
        // Statement reveal は既存 CSS (.philosophy.in-view .statement .line の blur+opacity+translateY transition) に任せる
        // GSAP は CSS と競合しないものだけ担当

        // Image parallax — Mission / Vision / How / About split-visual
        const parallaxImages = document.querySelectorAll(".split-visual-img");
        parallaxImages.forEach((img) => {
          gsap.fromTo(
            img,
            { yPercent: -8 },
            {
              yPercent: 8,
              ease: "none",
              scrollTrigger: {
                trigger: img.closest("section"),
                start: "top bottom",
                end: "bottom top",
                scrub: true,
              },
            }
          );
        });

        // Architecture 5 Layer — sequential reveal
        const layerItems = document.querySelectorAll(".architecture-layers .layer");
        if (layerItems.length > 0) {
          gsap.from(layerItems, {
            x: -32,
            opacity: 0,
            duration: 0.7,
            ease: "power2.out",
            stagger: 0.12,
            clearProps: "transform,opacity",
            scrollTrigger: {
              trigger: layerItems[0].closest("section"),
              start: "top 70%",
              toggleActions: "play none none none",
            },
          });
        }

        // Works 4 cards — stagger entrance (preserve staggered grid transform)
        const projectItems = document.querySelectorAll(".project-item");
        if (projectItems.length > 0) {
          gsap.from(projectItems, {
            y: 40,
            opacity: 0,
            duration: 0.8,
            ease: "power2.out",
            stagger: 0.1,
            clearProps: "transform,opacity",
            scrollTrigger: {
              trigger: projectItems[0].closest("section"),
              start: "top 75%",
              toggleActions: "play none none none",
            },
          });
        }

        // Journal cards — stagger entrance
        const journalItems = document.querySelectorAll(".journal-item");
        if (journalItems.length > 0) {
          gsap.from(journalItems, {
            y: 32,
            opacity: 0,
            duration: 0.7,
            ease: "power2.out",
            stagger: 0.08,
            clearProps: "transform,opacity",
            scrollTrigger: {
              trigger: journalItems[0].closest("section"),
              start: "top 75%",
              toggleActions: "play none none none",
            },
          });
        }

        // Members section — intro / hint accent on scroll-in
        const membersSection = document.querySelector(".members-section");
        if (membersSection) {
          const introEl = membersSection.querySelector(".intro");
          const memberCards = membersSection.querySelectorAll(".member");
          if (introEl) {
            gsap.from(introEl, {
              y: 24,
              opacity: 0,
              duration: 0.8,
              ease: "power2.out",
              clearProps: "transform,opacity",
              scrollTrigger: {
                trigger: membersSection,
                start: "top 75%",
                toggleActions: "play none none none",
              },
            });
          }
          if (memberCards.length > 0) {
            gsap.from(memberCards, {
              y: 30,
              opacity: 0,
              duration: 0.7,
              ease: "power2.out",
              stagger: 0.06,
              clearProps: "transform,opacity",
              scrollTrigger: {
                trigger: membersSection,
                start: "top 70%",
                toggleActions: "play none none none",
              },
            });
          }
        }

        // iOS Safari の vh / scroll 高さ計算ずれ対策: refresh を deferred で呼ぶ
        window.addEventListener("load", () => {
          ScrollTrigger.refresh();
        });
      }

      // Side nav active highlight
      const idSections = document.querySelectorAll("section[id]");
      const navLinks = document.querySelectorAll(".side-nav a");
      const navObs = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const id = entry.target.id;
              navLinks.forEach((link) => {
                link.classList.toggle(
                  "active",
                  link.getAttribute("href") === "#" + id
                );
              });
            }
          });
        },
        { rootMargin: "-45% 0px -45% 0px" }
      );
      idSections.forEach((s) => navObs.observe(s));

      // Mobile menu toggle
      const menuToggle = document.querySelector(".mobile-menu-toggle");
      const mobileMenu = document.getElementById("mobile-menu");
      if (menuToggle && mobileMenu) {
        const menuLinks = mobileMenu.querySelectorAll("a");
        const openMenu = () => {
          menuToggle.setAttribute("aria-expanded", "true");
          mobileMenu.setAttribute("aria-hidden", "false");
          menuToggle.setAttribute("aria-label", "メニューを閉じる");
          document.body.style.overflow = "hidden";
        };
        const closeMenu = () => {
          menuToggle.setAttribute("aria-expanded", "false");
          mobileMenu.setAttribute("aria-hidden", "true");
          menuToggle.setAttribute("aria-label", "メニューを開く");
          document.body.style.overflow = "";
        };
        menuToggle.addEventListener("click", () => {
          const isOpen = menuToggle.getAttribute("aria-expanded") === "true";
          if (isOpen) closeMenu();
          else openMenu();
        });
        menuLinks.forEach((link) => link.addEventListener("click", closeMenu));
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape" && menuToggle.getAttribute("aria-expanded") === "true") {
            closeMenu();
          }
        });
      }
    </script>
  </body>
</html>

