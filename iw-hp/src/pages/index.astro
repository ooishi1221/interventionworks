      transform: scale(1.03);
    }
  }

  .member-img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    display: block;
    filter: saturate(1) brightness(1);
    transition:
      filter 0.4s ease,
      transform 0.4s ease;
  }

  .member-info {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .member-name-block {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }

  .member-name {
    font-family: "Futura", "Helvetica Neue", sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--white);
    letter-spacing: -0.03em;
  }

  .member-jp {
    font-family: "Noto Sans JP", "Source Han Sans", sans-serif;
    font-size: 0.85rem;
    color: var(--teal);
    opacity: 0.85;
  }

  .member-role {
    font-family: "Futura", "Helvetica Neue", sans-serif;
    font-size: 0.75rem;
    color: var(--yellow);
    font-style: italic;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.85;
  }

  .member-desc {
    font-family: "Noto Sans JP", "Source Han Sans", sans-serif;
    font-size: 0.9rem;
    color: var(--teal);
    line-height: 1.7;
    opacity: 0.95;
  }

  /* === Portfolio === */
  .portfolio-section {
    max-width: 100ch;
    position: relative;
  }

  .portfolio-section::before {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    left: calc(50% - 50vw);
    right: calc(50% - 50vw);
    background:
      radial-gradient(ellipse 70% 60% at 80% 30%, rgba(15, 184, 184, 0.08) 0%, transparent 65%),
      radial-gradient(ellipse 50% 50% at 15% 75%, rgba(255, 200, 87, 0.05) 0%, transparent 70%);
    z-index: -1;
    pointer-events: none;
  }

  .projects {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem 4rem;
    margin: 2rem 0 0;
    padding: 0;
  }

  .project-item {
    list-style: none;
  }

  .project {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 2rem 1.5rem 2rem 2rem;
    border-left: 1px solid rgba(15, 184, 184, 0.25);
    background: linear-gradient(180deg, rgba(15, 184, 184, 0.02) 0%, transparent 100%);
    transition: transform 0.5s ease, border-color 0.4s ease, background 0.4s ease;
    text-decoration: none;
    color: inherit;
  }

  .project-item:nth-child(1) .project { transform: translateY(-1rem) rotate(-0.4deg); }
  .project-item:nth-child(2) .project { transform: translateY(2.5rem) rotate(0.5deg); }
  .project-item:nth-child(3) .project { transform: translateY(-3rem) rotate(0.3deg); }
  .project-item:nth-child(4) .project { transform: translateY(1.5rem) rotate(-0.6deg); }

  @media (hover: hover) {
    a.project:hover {
      border-left-color: var(--yellow);
      background: linear-gradient(180deg, rgba(255, 200, 87, 0.05) 0%, transparent 100%);
    }

    .project-item:nth-child(1) a.project:hover { transform: translateY(-1.8rem) rotate(0deg); }
    .project-item:nth-child(2) a.project:hover { transform: translateY(1.8rem) rotate(0deg); }
    .project-item:nth-child(3) a.project:hover { transform: translateY(-3.8rem) rotate(0deg); }
    .project-item:nth-child(4) a.project:hover { transform: translateY(0.8rem) rotate(0deg); }
  }

  .project-locked {
    cursor: not-allowed;
    opacity: 0.65;
  }

  .project-num {
    position: absolute;
    top: 0.5rem;
    right: 1rem;
    font-family: "Futura", "Helvetica Neue", sans-serif;
    font-size: clamp(4rem, 8vw, 6rem);
    font-weight: 700;
    color: var(--yellow);
    line-height: 1;
    letter-spacing: -0.06em;
    opacity: 0.15;
    pointer-events: none;
    font-feature-settings: "tnum";
    transition: opacity 0.4s ease, transform 0.5s ease;
  }

  @media (hover: hover) {
    a.project:hover .project-num {
      opacity: 0.45;
      transform: translateY(-0.3rem);
    }
  }

  .project-category {
    display: inline-block;
    align-self: flex-start;
    margin-top: 0.75rem;
    padding: 0.3rem 0.7rem;
    font-family: "Noto Sans JP", "Source Han Sans", sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--yellow);
    background: rgba(255, 200, 87, 0.08);
    border: 1px solid rgba(255, 200, 87, 0.3);
  }

  .project-name {
    font-family: "Futura", "Helvetica Neue", sans-serif;
    font-size: clamp(1.6rem, 3.2vw, 2.2rem);
    font-weight: 700;
    color: var(--white);
    letter-spacing: -0.04em;
    line-height: 1.1;
    margin-top: 0.6rem;
  }

  .project-tagline {
    font-family: "Noto Sans JP", "Source Han Sans", sans-serif;
    font-size: clamp(0.9rem, 1.4vw, 1.05rem);
    color: var(--teal);
    line-height: 1.7;
    opacity: 0.95;
    margin: 0;
  }

  .project-explore {
    font-family: "Futura", "Helvetica Neue", sans-serif;
    font-size: 0.78rem;
    color: var(--white);
    align-self: flex-start;
    letter-spacing: 0.18em;
    margin-top: 0.75rem;
    padding-bottom: 0.2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.4);
    opacity: 0.55;
    transition: opacity 0.3s ease, color 0.3s ease, border-color 0.3s ease, gap 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .project-explore .arrow {
    color: var(--yellow);
    transition: transform 0.3s ease;
  }

  @media (hover: hover) {
    a.project:hover .project-explore {
      opacity: 1;
      color: var(--yellow);
      border-bottom-color: var(--yellow);
    }

    a.project:hover .project-explore .arrow {
      transform: translateX(0.25rem);
    }
  }

  .project-status {
    font-family: "Futura", "Helvetica Neue", sans-serif;
    font-size: 0.72rem;
    color: var(--teal);
    align-self: flex-start;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin-top: 0.75rem;
    padding: 0.3rem 0.75rem;
    border: 1px solid rgba(15, 184, 184, 0.3);
    opacity: 0.6;
  }

  @media (max-width: 720px) {
    .projects {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .project-item:nth-child(1) .project,
    .project-item:nth-child(2) .project,
    .project-item:nth-child(3) .project,
    .project-item:nth-child(4) .project {
      transform: none;
    }
  }

  /* === Company === */
  .company-details {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin: 0;
    padding: 0;
  }

  .company-details > div {
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: 1.5rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid rgba(15, 184, 184, 0.15);
  }

  .company-details > div:last-child {
    border-bottom: none;
  }

  .company-details dt {
    font-family: "Futura", "Helvetica Neue", sans-serif;
    font-size: 0.8rem;
    color: var(--yellow);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0.85;
    margin: 0;
  }

  .company-details dd {
    font-family: "Noto Sans JP", "Source Han Sans", sans-serif;
    font-size: 1rem;
    color: var(--white);
    margin: 0;
    letter-spacing: -0.01em;
  }

  /* === Contact === */
  .contact-section {
    max-width: 72ch;
  }

  .contact-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1rem;
  }

  .contact-links a {
    font-family: "Futura", "Helvetica Neue", sans-serif;
    font-size: 1.1rem;
    color: var(--white);
    text-decoration: none;
    border-bottom: 1px solid var(--white);
    padding-bottom: 0.25rem;
    letter-spacing: -0.01em;
    transition:
      color 0.2s ease,
      border-color 0.2s ease;
  }

  .contact-links a:hover {
    color: var(--yellow);
    border-bottom-color: var(--yellow);
  }

  /* === Footer === */
  .footer {
    padding: 6vh 8vw;
    border-top: 1px solid rgba(15, 184, 184, 0.15);
  }

  .footer-text {
    font-family: "Futura", "Helvetica Neue", sans-serif;
    font-size: 0.85rem;
    color: var(--teal);
    opacity: 0.6;
    letter-spacing: 0.02em;
  }

  /* === Hero curtain (open animation) === */
  /* === Hero curtain entrance === */
  .hero-curtain {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: var(--navy);
    transform-origin: top;
    animation: curtainOpen 1.3s cubic-bezier(0.77, 0, 0.18, 1) 0.3s forwards;
    pointer-events: none;
    will-change: transform;
  }

  @keyframes curtainOpen {
    0% { transform: scaleY(1); }
    100% { transform: scaleY(0); }
  }

  .hero-content > * {
    opacity: 0;
    transform: translateY(1.5rem);
    animation: heroFadeUp 1.1s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }

  .hero-content .brand { animation-delay: 1.1s; }
  .hero-content .rotator { animation-delay: 1.4s; }
  .hero-content .mission-hero { animation-delay: 1.7s; }
  .hero-content .brand-sub { animation-delay: 2.0s; }

  @keyframes heroFadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .scroll-hint {
    opacity: 0;
    animation: bounce 2.4s ease-in-out 2.2s infinite, scrollHintIn 0.8s ease 2.2s forwards;
  }

  @keyframes scrollHintIn {
    to { opacity: 0.6; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-curtain {
      animation-duration: 0.4s;
      animation-delay: 0s;
    }
    .hero-content > * {
      animation-duration: 0.3s;
      animation-delay: 0s;
    }
    .scroll-hint {
      animation: scrollHintIn 0.3s ease 0.4s forwards;
    }
  }

  /* === Stats === */
  /* === Architecture Layers === */
  .architecture-layers {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin: 1.5rem 0 0;
    padding: 0;
    counter-reset: layer-counter;
  }

  .layer {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1rem 0;
    border-top: 1px solid rgba(15, 184, 184, 0.18);
    transition: border-color 0.3s ease, transform 0.3s ease;
  }

  @media (hover: hover) {
    .layer:hover {
      border-top-color: var(--yellow);
      transform: translateX(4px);
    }
  }

  .layer-num {
    font-family: "Futura", "Helvetica Neue", sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--yellow);
    letter-spacing: 0.12em;
    margin-right: 0.5rem;
    font-feature-settings: "tnum";
    opacity: 0.9;
  }

  .layer-name {
    font-family: "Futura", "Helvetica Neue", sans-serif;
    font-size: clamp(1.05rem, 1.7vw, 1.3rem);
    font-weight: 700;
    color: var(--white);
    letter-spacing: -0.01em;
    margin: 0;
    line-height: 1.4;
  }

  .layer-jp {
    font-family: "Noto Sans JP", "Source Han Sans", sans-serif;
    font-size: 0.78rem;
    font-weight: 400;
    color: var(--teal);
    margin-left: 0.6rem;
    letter-spacing: 0.05em;
    opacity: 0.85;
  }

  .layer-detail {
    font-family: "Noto Sans JP", "Source Han Sans", sans-serif;
    font-size: clamp(0.92rem, 1.4vw, 1rem);
    color: var(--teal);
    line-height: 1.75;
    opacity: 0.95;
    margin: 0;
  }

  .detail-closing {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(15, 184, 184, 0.15);
    font-style: italic;
    opacity: 0.85;
  }

  /* === Hero grid === */
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: 5vw;
    align-items: center;
    width: 100%;
  }

  .hero-visual {
    position: relative;
  }

  .hero-visual-img {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    display: block;
    filter: saturate(1.05);
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    max-width: 55ch;
    position: relative;
    z-index: 1;
  }

  /* === Split layout (左右交互 sukima 流) === */
  .split-layout {
    max-width: 100% !important;
    display: grid !important;
    grid-template-columns: 1fr 1fr;
    gap: 5vw;
    align-items: center;
  }

  .split-content {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    min-width: 0;
  }

  .split-visual {
    position: relative;
    overflow: hidden;
    background: var(--navy);
    -webkit-mask-image: radial-gradient(
      ellipse 95% 95% at center,
      black 30%,
      rgba(0, 0, 0, 0.6) 70%,
      transparent 100%
    );
    mask-image: radial-gradient(
      ellipse 95% 95% at center,
      black 30%,
      rgba(0, 0, 0, 0.6) 70%,
      transparent 100%
    );
  }

  .split-visual::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at center, rgba(5, 16, 34, 0) 20%, rgba(5, 16, 34, 0.4) 100%);
    pointer-events: none;
    transition: opacity 0.8s ease;
  }

  @media (hover: hover) {
    .split-layout:hover .split-visual::after {
      opacity: 0.5;
    }
  }

  .split-visual-img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    display: block;
    opacity: 0.85;
    filter: saturate(0.7) brightness(0.85) contrast(1.05);
    transition: transform 0.8s ease, opacity 0.8s ease, filter 0.8s ease;
  }

  @media (hover: hover) {
    .split-layout:hover .split-visual-img {
      transform: scale(1.03);
      opacity: 1;
      filter: saturate(1) brightness(1) contrast(1);
    }
  }

  .split-layout.layout-left .split-content {
    order: 1;
  }

  .split-layout.layout-left .split-visual {
    order: 2;
  }

  .split-layout.layout-right .split-content {
    order: 2;
  }

  .split-layout.layout-right .split-visual {
    order: 1;
  }

  @media (max-width: 900px) {
    .hero-grid,
    .split-layout {
      grid-template-columns: 1fr !important;
      gap: 3rem;
    }

    .split-layout.layout-left .split-content,
    .split-layout.layout-left .split-visual,
    .split-layout.layout-right .split-content,
    .split-layout.layout-right .split-visual {
      order: 0;
    }

    .split-visual {
      display: none;
    }
  }

  /* === Side nav === */
  .side-nav {
    position: fixed;
    top: 50%;
    right: 2.5vw;
    transform: translateY(-50%);
    z-index: 100;
  }

  .side-nav ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    margin: 0;
    padding: 0;
  }

  .side-nav a {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--teal);
    font-family: "Futura", "Helvetica Neue", sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0.45;
    transition:
      opacity 0.3s ease,
      color 0.3s ease,
      transform 0.3s ease;
  }

  .side-nav a::before {
    content: attr(data-num);
    font-feature-settings: "tnum";
    font-size: 0.65rem;
    opacity: 0.7;
  }

  .side-nav a:hover,
  .side-nav a.active {
    opacity: 1;
    color: var(--yellow);
    transform: translateX(-4px);
  }

  @media (max-width: 768px) {
    .side-nav {
      display: none;
    }
  }

  /* === Mobile menu (hamburger) === */
  .mobile-menu-toggle {
    display: none;
    position: fixed;
    top: 1.2rem;
    right: 1.2rem;
    z-index: 200;
    width: 48px;
    height: 48px;
    background: var(--navy);
    border: 1px solid rgba(15, 184, 184, 0.3);
    cursor: pointer;
    padding: 0;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    transition: border-color 0.3s ease;
  }

  .mobile-menu-toggle:hover,
  .mobile-menu-toggle:focus-visible {
    border-color: var(--yellow);
    outline: none;
  }

  .mobile-menu-toggle .bar {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--teal);
    transition: transform 0.3s ease, opacity 0.3s ease, background 0.3s ease;
  }

  .mobile-menu-toggle[aria-expanded="true"] .bar {
    background: var(--yellow);
  }

  .mobile-menu-toggle[aria-expanded="true"] .bar:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }

  .mobile-menu-toggle[aria-expanded="true"] .bar:nth-child(2) {
    opacity: 0;
  }

  .mobile-menu-toggle[aria-expanded="true"] .bar:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  .mobile-menu {
    position: fixed;
    inset: 0;
    background: rgba(5, 16, 34, 0.97);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    z-index: 150;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 8vh 8vw;
  }

  .mobile-menu[aria-hidden="false"] {
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-menu ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 0;
    margin: 0;
  }

  .mobile-menu a {
    font-family: "Futura", "Helvetica Neue", sans-serif;
    font-size: clamp(1.8rem, 7vw, 2.6rem);
    color: var(--white);
    text-decoration: none;
    font-weight: 700;
    letter-spacing: -0.02em;
    display: flex;
    align-items: baseline;
    gap: 1rem;
    transition: color 0.3s ease, transform 0.3s ease;
  }

  .mobile-menu a::before {
    content: attr(data-num);
    font-size: 0.85rem;
    color: var(--yellow);
    font-weight: 700;
    letter-spacing: 0.15em;
    opacity: 0.7;
    font-family: "Futura", "Helvetica Neue", sans-serif;
  }

  .mobile-menu a:active,
  .mobile-menu a:hover {
    color: var(--yellow);
    transform: translateX(8px);
  }

  @media (max-width: 768px) {
    .mobile-menu-toggle {
      display: flex;
    }
  }

  @media (min-width: 769px) {
    .mobile-menu {
      display: none;
    }
  }

  /* === Hero rotator === */
  .rotator {
    position: relative;
    height: clamp(3rem, 8vw, 6rem);
    width: 100%;
    overflow: hidden;
  }

  .rotator-word {
    position: absolute;
    top: 0;
    left: 0;
    font-family: "Futura", "Helvetica Neue", sans-serif;
    font-size: clamp(2.2rem, 6vw, 4.5rem);
    font-weight: 700;
    color: var(--yellow);
    letter-spacing: -0.03em;
    line-height: 1;
    opacity: 0;
    transform: translateY(20px);
    animation: rotateWords 21s linear infinite;
  }

  .rotator-word:nth-child(1) { animation-delay: 0s; }
  .rotator-word:nth-child(2) { animation-delay: 1.5s; }
  .rotator-word:nth-child(3) { animation-delay: 3s; }
  .rotator-word:nth-child(4) { animation-delay: 4.5s; }
  .rotator-word:nth-child(5) { animation-delay: 6s; }
  .rotator-word:nth-child(6) { animation-delay: 7.5s; }
  .rotator-word:nth-child(7) { animation-delay: 9s; }
  .rotator-word:nth-child(8) { animation-delay: 10.5s; }
  .rotator-word:nth-child(9) { animation-delay: 12s; }
  .rotator-word:nth-child(10) { animation-delay: 13.5s; }
  .rotator-word:nth-child(11) { animation-delay: 15s; }
  .rotator-word:nth-child(12) { animation-delay: 16.5s; }
  .rotator-word:nth-child(13) { animation-delay: 18s; }
  .rotator-word:nth-child(14) { animation-delay: 19.5s; }

  @keyframes rotateWords {
    0% {
      opacity: 0;
      transform: translateY(20px);
    }
    3% {
      opacity: 1;
      transform: translateY(0);
    }
    9% {
      opacity: 1;
      transform: translateY(0);
    }
    12% {
      opacity: 0;
      transform: translateY(-20px);
    }
    100% {
      opacity: 0;
      transform: translateY(-20px);
    }
  }

  /* === Mobile responsive === */
  @media (max-width: 640px) {
    section {
      padding: 8vh 6vw;
    }

    .hero {
      padding: 6vh 6vw;
      gap: 2.5rem;
      min-height: 90vh;
    }

    .core-words {
      gap: 0.75rem 1.25rem;
    }

    .philosophy {
      gap: 1.5rem;
    }

    .members {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .commitments {
      gap: 2rem;
    }

    .projects {
      gap: 1.5rem;
    }

    .footer {
