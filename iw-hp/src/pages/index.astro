// note RSS を build 時に fetch（intervention.jp 連載「ゆう&ベッキー」)
type JournalArticle = {
  title: string;
  link: string;
  thumbnail: string;
  pubDate: string;
  pubDateLabel: string;
};

async function fetchJournalArticles(limit = 5): Promise<JournalArticle[]> {
  try {
    const res = await fetch("https://note.com/intervention_jp/rss", {
      headers: { "User-Agent": "intervention.jp-astro-build" },
    });
    if (!res.ok) return [];
    const xml = await res.text();
    const items = xml.split(/<item>/).slice(1, limit + 1);
    return items.map((raw) => {
      const block = raw.split(/<\/item>/)[0];
      const pick = (re: RegExp) => {
        const m = block.match(re);
        return m ? m[1].trim() : "";
      };
      const title = pick(/<title>([\s\S]*?)<\/title>/)
        .replace(/<!\[CDATA\[/g, "")
        .replace(/\]\]>/g, "");
      const link = pick(/<link>([\s\S]*?)<\/link>/);
      const thumbnail = pick(/<media:thumbnail>([\s\S]*?)<\/media:thumbnail>/);
      const pubDate = pick(/<pubDate>([\s\S]*?)<\/pubDate>/);
      const date = pubDate ? new Date(pubDate) : null;
      const pubDateLabel = date
        ? `${date.getFullYear()}.${String(date.getMonth() + 1).padStart(2, "0")}.${String(date.getDate()).padStart(2, "0")}`
        : "";
      return { title, link, thumbnail, pubDate, pubDateLabel };
    });
  } catch (e) {
    return [];
  }
}

const journalArticles = await fetchJournalArticles(5);

