    </li>
  </ul>

  <style>
    .compare-table {
      width: 100%;
      max-width: 65ch;
      margin: 1.5rem 0 2rem;
      border-collapse: collapse;
      font-size: 0.92rem;
    }

    .compare-table thead th {
      font-family: "Futura", "Helvetica Neue", sans-serif;
      font-size: 0.72rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--yellow);
      font-weight: 700;
      text-align: left;
      padding: 0.75rem 1rem;
      border-bottom: 1px solid rgba(255, 200, 87, 0.3);
      opacity: 0.85;
    }

    .compare-table tbody td {
      padding: 0.9rem 1rem;
      border-bottom: 1px solid rgba(15, 184, 184, 0.1);
      color: var(--teal);
      vertical-align: top;
    }

    .compare-table tbody td:first-child {
      font-family: "Futura", "Helvetica Neue", sans-serif;
      font-size: 0.78rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--teal);
      opacity: 0.6;
      width: 8rem;
    }

    .compare-table tbody td strong {
      color: var(--yellow);
      font-weight: 700;
    }

    @media (max-width: 640px) {
      .compare-table tbody td:first-child {
        width: 6rem;
      }
    }
  </style>
</WorkLayout>
