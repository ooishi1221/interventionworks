---
interface Props {
  title: string;
  description: string;
  num: string;
  name: string;
  tagline: string;
}

const { title, description, num, name, tagline } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} — Intervention Works</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="article" />
    <meta property="og:title" content={`${title} — Intervention Works`} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Intervention Works" />
    <meta property="og:locale" content="ja_JP" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@intervention_jp" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&family=Noto+Serif+JP:wght@400;700;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <nav class="work-nav-top">
      <a href="/#works" class="work-back-link">
        <span class="arrow">←</span>
        <span>BACK TO WORKS</span>
      </a>
    </nav>

    <main class="work-main">
      <header class="work-header">
        <span class="work-num">( {num} / works )</span>
        <h1 class="work-name">{name}</h1>
        <p class="work-tagline">{tagline}</p>
      </header>

      <div class="work-body">
        <slot />
      </div>
    </main>

    <footer class="work-footer">
      <div class="work-footer-inner">
        <a href="/" class="work-back-link">
          <span class="arrow">←</span>
          <span>INTERVENTION WORKS</span>
        </a>
        <p class="work-footer-tag">魂の震えに介入せよ</p>
      </div>
    </footer>

    <style is:global>
      :root {
        --teal: #0fb8b8;
        --navy: #051022;
        --yellow: #ffc857;
        --black: #000000;
        --white: #ffffff;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html,
      body {
        min-height: 100vh;
        background: var(--navy);
        color: var(--teal);
        font-family: "Noto Sans JP", "Source Han Sans", sans-serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      a {
        color: inherit;
      }

      /* Keyboard navigation focus indicator */
      a:focus-visible,
      button:focus-visible {
        outline: 2px solid var(--yellow);
        outline-offset: 4px;
        border-radius: 2px;
      }
    </style>

    <style>
      .work-nav-top {
        position: sticky;
        top: 0;
        z-index: 10;
        backdrop-filter: blur(12px);
        background: rgba(5, 16, 34, 0.65);
        padding: 1.25rem 6vw;
        border-bottom: 1px solid rgba(15, 184, 184, 0.1);
      }

      .work-back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        font-family: "Futura", "Helvetica Neue", sans-serif;
        font-size: 0.72rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--teal);
        text-decoration: none;
        opacity: 0.7;
        transition: opacity 0.3s ease, color 0.3s ease, gap 0.3s ease;
      }

      .work-back-link:hover {
        opacity: 1;
        color: var(--yellow);
        gap: 0.85rem;
      }

      .work-back-link .arrow {
        color: var(--yellow);
        font-size: 0.85rem;
      }

      .work-main {
        max-width: 800px;
        margin: 0 auto;
        padding: 8vh 6vw 12vh;
      }

      .work-header {
        margin-bottom: 6vh;
        padding-bottom: 4vh;
        border-bottom: 1px solid rgba(15, 184, 184, 0.15);
      }

      .work-num {
        display: block;
        font-family: "Futura", "Helvetica Neue", sans-serif;
        font-size: 0.78rem;
        color: var(--teal);
        letter-spacing: 0.25em;
        text-transform: lowercase;
        opacity: 0.55;
        margin-bottom: 1.2rem;
      }

      .work-name {
        font-family: "Futura", "Helvetica Neue", sans-serif;
        font-size: clamp(2.5rem, 8vw, 5rem);
        font-weight: 700;
        color: var(--white);
        letter-spacing: -0.05em;
        line-height: 1;
        margin-bottom: 1.5rem;
      }

      .work-tagline {
        font-family: "Noto Sans JP", "Source Han Sans", sans-serif;
        font-size: clamp(1rem, 1.8vw, 1.2rem);
        color: var(--teal);
        line-height: 1.7;
        opacity: 0.85;
        max-width: 60ch;
      }

      .work-body {
        font-family: "Noto Sans JP", "Source Han Sans", sans-serif;
        font-size: 1rem;
        line-height: 1.95;
        color: var(--teal);
      }

      .work-body :global(h2) {
        font-family: "Futura", "Helvetica Neue", sans-serif;
        font-size: clamp(1.5rem, 3vw, 2rem);
        font-weight: 700;
        color: var(--white);
        letter-spacing: -0.03em;
        margin: 5rem 0 1.5rem;
        padding-top: 2rem;
        border-top: 1px solid rgba(15, 184, 184, 0.15);
      }

      .work-body :global(h2 .label) {
        display: block;
        font-family: "Futura", "Helvetica Neue", sans-serif;
        font-size: 0.7rem;
        color: var(--yellow);
        letter-spacing: 0.25em;
        text-transform: uppercase;
        opacity: 0.7;
        margin-bottom: 0.8rem;
        font-weight: 400;
      }

      .work-body :global(h3) {
        font-family: "Futura", "Helvetica Neue", sans-serif;
        font-size: clamp(1.1rem, 2vw, 1.3rem);
        font-weight: 700;
        color: var(--white);
        letter-spacing: -0.02em;
        margin: 2.5rem 0 1rem;
      }

      .work-body :global(p) {
        margin-bottom: 1.5rem;
        max-width: 65ch;
      }

      .work-body :global(p.lead) {
        font-size: clamp(1.05rem, 1.6vw, 1.15rem);
        color: var(--white);
        opacity: 0.95;
      }

      .work-body :global(ul),
      .work-body :global(ol) {
        margin: 0 0 1.5rem 1.5rem;
        max-width: 65ch;
      }

      .work-body :global(li) {
        margin-bottom: 0.5rem;
      }

      .work-body :global(strong),
      .work-body :global(.accent) {
        color: var(--yellow);
        font-weight: 700;
      }

      .work-body :global(a.inline-link) {
        color: var(--yellow);
        text-decoration: none;
        border-bottom: 1px solid rgba(255, 200, 87, 0.4);
        transition: border-color 0.3s ease;
      }

      .work-body :global(a.inline-link:hover) {
        border-bottom-color: var(--yellow);
      }

      .work-body :global(blockquote) {
        margin: 2.5rem 0;
        padding: 1.25rem 1.5rem;
        border-left: 2px solid var(--yellow);
        background: rgba(15, 184, 184, 0.04);
        font-family: "Noto Serif JP", "Source Han Serif", serif;
        font-size: clamp(1.05rem, 1.7vw, 1.2rem);
        color: var(--white);
        line-height: 1.9;
        max-width: none;
      }

      .work-body :global(.link-list) {
        list-style: none;
        margin: 1rem 0 0 0;
        padding: 0;
      }

      .work-body :global(.link-list li) {
        margin-bottom: 0.75rem;
      }

      .work-body :global(.link-list a) {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: "Futura", "Helvetica Neue", sans-serif;
        font-size: 0.8rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--white);
        text-decoration: none;
        padding-bottom: 0.2rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.3);
        opacity: 0.7;
        transition: opacity 0.3s ease, color 0.3s ease, gap 0.3s ease, border-color 0.3s ease;
      }

      .work-body :global(.link-list a:hover) {
        opacity: 1;
        color: var(--yellow);
        border-bottom-color: var(--yellow);
        gap: 0.75rem;
      }

      .work-body :global(.link-list a .arrow) {
        color: var(--yellow);
      }

      .work-footer {
        padding: 6vh 6vw 8vh;
        border-top: 1px solid rgba(15, 184, 184, 0.1);
      }

      .work-footer-inner {
        max-width: 800px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 2rem;
        flex-wrap: wrap;
      }

      .work-footer-tag {
        font-family: "Futura", "Helvetica Neue", sans-serif;
        font-size: 0.72rem;
        letter-spacing: 0.25em;
        text-transform: lowercase;
        color: var(--teal);
        opacity: 0.45;
      }

      @media (max-width: 640px) {
        .work-main {
          padding: 6vh 8vw 10vh;
        }

        .work-footer {
          padding: 5vh 8vw 7vh;
        }

        .work-footer-inner {
          flex-direction: column;
          align-items: flex-start;
        }
      }
    </style>
  </body>
</html>
