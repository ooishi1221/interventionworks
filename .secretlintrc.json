{
  "rules": [
    {
      "id": "@secretlint/secretlint-rule-preset-recommend"
    },
    {
      "id": "@secretlint/secretlint-rule-pattern",
      "options": {
        "patterns": [
          {
            "name": "Gemini / Google Generative AI API key",
            "pattern": "/(?<=GEMINI_API_KEY|GOOGLE_GENAI_API_KEY|GOOGLE_AI_API_KEY)[\\s:=\"']+AIza[0-9A-Za-z_-]{35}\\b/g"
          },
          {
            "name": "Google Maps / Places API key (server-side label)",
            "pattern": "/(?<=GOOGLE_MAPS_API_KEY|PLACES_API_KEY|SERVER_GOOGLE_API_KEY)[\\s:=\"']+AIza[0-9A-Za-z_-]{35}\\b/g"
          },
          {
            "name": "AWS Access Key ID",
            "pattern": "/\\b(AKIA|ASIA)[0-9A-Z]{16}\\b/g"
          },
          {
            "name": "OpenAI API key",
            "pattern": "/\\bsk-(proj-)?[A-Za-z0-9_-]{20,}\\b/g"
          },
          {
            "name": "Sentry auth token",
            "pattern": "/\\bsntrys_[A-Za-z0-9+/=_-]{24,}\\b/g"
          }
        ]
      }
    }
  ]
}
