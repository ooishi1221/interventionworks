# X API @intervention_jp
#
# 取得手順は yu-api-setup.md を参照
# このファイル (.env.example) は git 管理、実値は .env に書く（.gitignore 済み）

# === X API 認証 (yu-api-setup.md Step 2-6) ===
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=
X_USER_ID=                          # Phase 2 (メンション polling) で必要、Phase 1 投稿のみなら空で OK

# === x-tweet クライアント設定 ===

# 初期は true（dry run、stdout に出力するだけで実投稿しない）
# 動作確認後 false に切り替え
X_TWEET_DRY_RUN=true

# 暴走防止、1 日上限（衝動 1 日 1 投稿目安だが、掛け合いの日は数件出る想定で 5 まで）
X_TWEET_MAX_PER_DAY=5

# safety-guard namelist のパス（safety-guard-namelist.example.txt をコピーして使う）
X_TWEET_NAMELIST_PATH=./safety-guard-namelist.txt

# === ログ・キュー（自動生成、編集不要）===
X_TWEET_LOG_PATH=./tweet-log.jsonl
X_MENTION_QUEUE_PATH=./mention-queue.jsonl

# === 緊急停止 craft（ファイル存在で発動、編集不要）===
# EMERGENCY_STOP ファイル存在時 → 即 abort
# PAUSE_UNTIL ファイル存在時 → ファイル内日付（YYYY-MM-DD）まで投稿停止
# 詳細は safety-guard.md 参照
