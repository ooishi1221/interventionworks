rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // spots: 認証済みユーザーのみ読み書き可。削除は禁止
    match /spots/{spotId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null
                   && resource.data.source == 'user'
                   && resource.data.createdBy == request.auth.uid;
    }

    // reviews: 認証済みユーザーのみ。更新・削除は本人のみ
    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.userId;
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.userId;
    }

    // users: 本人のみ読み書き
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // validations: 認証済みユーザーのみ作成・読取。更新・削除は禁止
    match /validations/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // announcements: 認証済みユーザーは読み取り可。作成も許可（将来的にAdmin限定に変更）
    match /announcements/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // moderation_logs: Admin SDK のみ（クライアントからはアクセス不可）
    match /moderation_logs/{docId} {
      allow read, write: if false;
    }

    // beta_errors: 認証ユーザーは作成のみ。読取・更新・削除は Admin SDK のみ
    match /beta_errors/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // beta_feedback: 認証ユーザーは作成のみ。読取・更新・削除は Admin SDK のみ
    match /beta_feedback/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // debug_reports: ユーザーがデバッグ情報をワンタップ送信するコレクション。
    // 認証ユーザーは作成のみ。読取・更新・削除は Admin SDK (Slack Bot) のみ
    match /debug_reports/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // inquiries: 設定画面からのお問い合わせ。
    // 認証ユーザーは作成のみ。読取・更新・削除は Admin SDK (管理画面) のみ
    match /inquiries/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // user_activity: 認証ユーザーは自分のアクティビティを記録可。DAU/WAU/MAU集計元
    match /user_activity/{docId} {
      allow create, update: if request.auth != null;
      allow read, delete: if false;
    }

    // push_tokens: 認証ユーザーは自分のトークンを登録・更新可
    match /push_tokens/{docId} {
      allow create, update: if request.auth != null;
      allow read, delete: if false;
    }

    // retention_log: Admin SDK のみ
    match /retention_log/{docId} {
      allow read, write: if false;
    }

    // user_blocks: 自分がブロックしたユーザーの uid 配列。
    // 本人のみ読み書き可。docId = 自分の auth.uid。
    match /user_blocks/{uid} {
      allow read, create, update: if request.auth != null
                                  && request.auth.uid == uid;
      allow delete: if false;
    }

    // reports: ワンショット通報（Apple Guideline 1.2 準拠）。
    // 認証ユーザーは作成のみ。読取・更新・削除は Admin SDK（Slack Bot / 管理画面）のみ
    match /reports/{docId} {
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.reporterUid;
      allow read, update, delete: if false;
    }
  }
}
