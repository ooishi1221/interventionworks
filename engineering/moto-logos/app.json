{
  "expo": {
    "name": "Moto-Logos",
    "slug": "moto-logos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1C1C1E"
    },
    "plugins": [
      "expo-sqlite",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "駐輪場の近接検知のため位置情報を使用します。"
        }
      ],
      "./plugins/withYahooNaviAndroid",
      "./plugins/withDisableLint",
      [
        "@sentry/react-native",
        {
          "organization": "moto-logos-team",
          "project": "moto-logos"
        }
      ],
      "expo-asset",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FF6B00"
        }
      ],
      "expo-apple-authentication",
      "@react-native-google-signin/google-signin",
      "expo-font"
    ],
    "ios": {
      "bundleIdentifier": "com.interventionworks.motologos",
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "comgooglemaps",
          "yjnavicar",
          "ynavigation"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.interventionworks.motologos",
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAqLnpZ8tiuP0YfsLMkLuRvd2TvUuwb98o"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1C1C1E"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "e0e8b07d-509a-4db3-9c39-c9360c774a18"
      }
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e0e8b07d-509a-4db3-9c39-c9360c774a18"
    },
    "owner": "yuji1221"
  }
}
