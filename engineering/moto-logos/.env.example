# Firebase
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google Sign-In
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Google Places API (Autocomplete + Details)
# Application restrictions は GCP の API key で 1 種類しか設定できないため、Android / iOS で別キーを発行する。
#   Android key: Android apps 制限 (パッケージ名 + SHA-1 fingerprint)
#   iOS key:     iOS apps 制限 (Bundle ID)
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY_ANDROID=
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY_IOS=

# Sentry
EXPO_PUBLIC_SENTRY_DSN=

# Contact
EXPO_PUBLIC_CONTACT_EMAIL=
